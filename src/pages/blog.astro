---
import "../styles/global.css";
import GoogleAnalytics from "../components/GoogleAnalytics.astro";

const instagramUrl = "https://www.instagram.com/instinct_voyageur/";

const articles = [
  {
    title: "Combien de temps prévoir pour visiter la Colombie ?",
    description:
      "10 jours, 15 jours, 3 semaines ou plus : comment choisir la bonne durée selon votre rythme et votre itinéraire.",
    href: "/combien-de-temps-visiter-colombie/",
    status: "Publié"
  },
  {
    title: "Préparer un premier voyage en Colombie : les erreurs à éviter",
    description:
      "Les mauvais réflexes qui font perdre du temps, de l’énergie et parfois de l’argent lors d’un premier voyage en Colombie.",
    href: "#",
    status: "À venir"
  }
];
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Manrope:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Blog | Maloka Experience</title>
    <meta
      name="description"
      content="Conseils pratiques pour organiser un voyage en Colombie : durée, itinéraire, sécurité, budget et erreurs à éviter."
    />
    <GoogleAnalytics />
  </head>
  <body>
    <div class="site-shell legal-page">
      <nav class="nav legal-nav" aria-label="Navigation principale">
        <a class="brand" href="/" aria-label="Maloka Experience">
          <span class="brand-symbol" aria-hidden="true">
            <img src="/images/maloka-logo-symbol.png" alt="" />
          </span>
          <span class="brand-text">Maloka Experience</span>
        </a>
        <div class="nav-links">
          <a href="/">Accueil</a>
          <a href="/#offres">Offres Travel Planner</a>
          <a href="/#projet-voyage">Contact</a>
        </div>
      </nav>

      <main>
        <section class="section legal-hero blog-hero">
          <div class="container legal-content">
            <p class="eyebrow">Blog</p>
            <h1>Conseils pour préparer votre voyage en Colombie</h1>
            <p class="legal-intro">
              Des articles pratiques pour choisir la bonne durée, éviter les erreurs classiques et
              construire un itinéraire plus fluide.
            </p>
          </div>
        </section>

        <section class="section blog-list-section">
          <div class="container blog-grid">
            {articles.map((article) => (
              <article class="blog-card">
                <span>{article.status}</span>
                <h2>{article.title}</h2>
                <p>{article.description}</p>
                <a href={article.href} aria-disabled={article.href === "#"}>
                  Lire l’article
                </a>
              </article>
            ))}
          </div>
        </section>
      </main>

      <footer class="footer">
        <div class="footer-inner">
          <a class="footer-logo" href="/" aria-label="Retour à l’accueil de Maloka Experience">
            <img src="/images/maloka-logo-full.png" alt="Logo Maloka Experience" loading="lazy" />
          </a>
          <div class="footer-center">
            <span>© 2026 Maloka Experience</span>
            <small>Travel planning sur mesure pour la Colombie</small>
          </div>
          <nav class="footer-links" aria-label="Liens de pied de page">
            <a href="/blog/">Blog</a>
            <a href="/mentions-legales/">Mentions légales</a>
            <a href="/cgv/">CGV</a>
            <a href="/politique-confidentialite/">Confidentialité</a>
            <a class="footer-social" href={instagramUrl} target="_blank" rel="noreferrer">
              <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5"></rect>
                <circle cx="12" cy="12" r="4"></circle>
                <circle cx="17.5" cy="6.5" r="1.2"></circle>
              </svg>
              Instagram
            </a>
          </nav>
        </div>
      </footer>
    </div>
  </body>
</html>
